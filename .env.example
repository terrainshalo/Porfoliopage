# EmailJS credentials — create a free account at https://www.emailjs.com
# Dashboard > Email Services (create a service, e.g. Gmail) -> copy the Service ID
# Dashboard > Email Templates (create a template) -> copy the Template ID
# Dashboard > Account > General -> copy the Public Key
#
# In your EmailJS template set the "To Email" field to: admin@terrainshalo.com
# and use these variables in the template body: {{from_name}} {{from_email}} {{subject}} {{message}}

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
